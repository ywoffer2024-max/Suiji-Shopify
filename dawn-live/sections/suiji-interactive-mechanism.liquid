{%- comment -%}
  SUIJI · Interactive mechanism (v3 — line-art configurator)
  Three hairline base drawings (ring / pendant / earring), each holds one charm
  in a fixed, drawn mount. Drag a charm onto ANY other base (whole panel is the
  target) or click/keyboard. Deterministic seating = always pixel-perfect.
{%- endcomment -%}

{{ 'suiji-mechanism.css' | asset_url | stylesheet_tag }}
<script src="{{ 'suiji-mechanism.js' | asset_url }}" defer></script>

{%- capture sets_json -%}
[
  {%- assign first_set = true -%}
  {%- for s in shop.metaobjects.jewelry_set.values -%}
    {%- liquid
      assign set_url = ''
      assign set_price = ''
      if s.product_ref.value != blank
        assign set_url = s.product_ref.value.url
        assign set_price = s.product_ref.value.price | money
      endif
    -%}
    {%- unless first_set -%},{%- endunless -%}{%- assign first_set = false -%}
    { "handle": {{ s.system.handle | json }}, "name": {{ s.name.value | json }},
      "url": {{ set_url | json }}, "price": {{ set_price | strip_html | json }},
      "charms": [
        {%- assign fc = true -%}
        {%- for c in s.charms.value -%}
          {%- liquid
            assign overlay = blank
            if c.image_overlay_png.value != blank
              assign overlay = c.image_overlay_png.value | image_url: width: 420
            elsif c.image_main.value != blank
              assign overlay = c.image_main.value | image_url: width: 420
            endif
          -%}
          {%- if overlay != blank -%}
            {%- unless fc -%},{%- endunless -%}{%- assign fc = false -%}
            { "handle": {{ c.system.handle | json }}, "name": {{ c.name.value | json }}, "overlay": {{ overlay | json }} }
          {%- endif -%}
        {%- endfor -%}
      ] }
  {%- endfor -%}
]
{%- endcapture -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width suiji-mech" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;">
    <p class="suiji-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="suiji-mech__heading">{{ section.settings.heading }}</h2>
    <p class="suiji-mech__sub">{{ section.settings.subheading }}</p>

    <ol class="suiji-mech__how" aria-label="How it works">
      <li><span>1</span> {{ section.settings.step_1 }}</li>
      <li><span>2</span> {{ section.settings.step_2 }}</li>
      <li><span>3</span> {{ section.settings.step_3 }}</li>
    </ol>

    <div class="suiji-mech__tabs" id="suiji-set-tabs" role="tablist" aria-label="Choose a set"></div>
    <p class="suiji-mech__try" id="suiji-try-hint" aria-hidden="true"></p>

    <div class="suiji-mech__scene" id="suiji-scene">
      {%- assign forms = 'ring,necklace,earring' | split: ',' -%}
      {%- assign labels = 'Ring,Pendant,Earring' | split: ',' -%}
      {%- for f in forms -%}
        {%- assign idx = forloop.index0 -%}
        <div class="suiji-mech__panel" data-form="{{ f }}">
          <svg class="suiji-mech__art" viewBox="0 0 300 300" aria-hidden="true" focusable="false">
            {%- case f -%}
              {%- when 'ring' -%}
                <ellipse cx="150" cy="240" rx="56" ry="18"/>
                <path d="M126,230 C121,200 134,168 143,150"/>
                <path d="M174,230 C179,200 166,168 157,150"/>
              {%- when 'necklace' -%}
                <path d="M150,70 Q95,26 48,12"/>
                <path d="M150,70 Q205,26 252,12"/>
                <circle cx="150" cy="66" r="6.5"/>
              {%- when 'earring' -%}
                <path d="M150,70 L150,48 A16 16 0 1 1 119 44"/>
            {%- endcase -%}
          </svg>
          <span class="suiji-mech__mount" aria-hidden="true"></span>
          <img class="suiji-mech__charm" alt="" hidden tabindex="0" role="button">
          <p class="suiji-mech__panel-label">{{ labels[idx] }}</p>
        </div>
      {%- endfor -%}
    </div>

    <div class="suiji-mech__cta" hidden>
      <p class="suiji-mech__cta-line"><span class="suiji-mech__cta-name"></span></p>
      <a class="button" href="#">{{ section.settings.cta_label }} <span class="suiji-mech__cta-price"></span></a>
    </div>
    <p class="suiji-mech__live visually-hidden" role="status" aria-live="polite"></p>
  </div>
</div>

<script type="application/json" id="suiji-mech-data">{{ sets_json | strip }}</script>

{% schema %}
{
  "name": "SUIJI · Mechanism game",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Try it yourself" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "One charm, every form" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Move a charm between the ring, pendant and earring. Watch it re-form." },
    { "type": "text", "id": "step_1", "label": "Step 1", "default": "Pick a set" },
    { "type": "text", "id": "step_2", "label": "Step 2", "default": "Drag a charm to another base" },
    { "type": "text", "id": "step_3", "label": "Step 3", "default": "It locks with a click" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View the set —" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "presets": [{ "name": "SUIJI · Mechanism game" }]
}
{% endschema %}
